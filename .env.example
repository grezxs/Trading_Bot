# Copy to .env (gitignored) and fill in. NEVER commit real keys.
# Keys are read from the environment only — never hard-coded in config.

# Mode: mock (offline, no keys) or testnet (Binance paper trading)
BOT_MODE=mock

# Spot testnet keys — free at https://testnet.binance.vision
BINANCE_TESTNET_API_KEY=
BINANCE_TESTNET_SECRET=

# Futures testnet keys (only if enabling shorting) — https://testnet.binancefuture.com
BINANCE_FUTURES_TESTNET_API_KEY=
BINANCE_FUTURES_TESTNET_SECRET=

# Optional
LOG_LEVEL=INFO
